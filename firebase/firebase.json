{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },

  "functions": {
    "source": "functions"
  },

  "emulators": {
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "dataconnect": {
      "port": 9100,
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },

  "dataconnect": {
    "source": "dataconnect"
  },

  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
